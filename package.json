{
  "name": "@swipegames/integration-sdk",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "version": "1.0.0",
  "type": "module",
  "description": "Node.js SDK for SwipeGames direct integration partners",
  "main": "./dist/index.js",
